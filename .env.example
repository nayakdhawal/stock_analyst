# n8n webhook URL for AI stock analysis
# Get this from your n8n instance under Workflow > Webhook node > Production URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Supabase connection details
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Allowed origins for the Python backend (comma-separated)
# Set this to your live app domain, e.g. https://myapp.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
